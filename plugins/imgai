import axios from "axios"

export default {
  name: "imageai",
  command: ["imgaifree "imageai2"],
  category: "ai",
  async execute({ sock, m, text }) {
    if (!text) return m.reply("Masukkan prompt!")

    try {
      const url = `https://image.pollinations.ai/prompt/${encodeURIComponent(text)}`
      
      await sock.sendMessage(m.chat, {
        image: { url },
        caption: `Hasil AI: ${text}`
      }, { quoted: m })

    } catch (e) {
      m.reply("Error generate image")
    }
  }
}
